# ── Symphony Docker Environment ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Each project/container can have its own .env file.

# Required: Linear API key for the project tracker
LINEAR_API_KEY=lin_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Required: OpenAI API key (or use `codex login` inside the container)
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: GitHub token for gh CLI / git push (or use `gh auth login` inside)
GH_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: Dashboard port on the host (default: 4000)
SYMPHONY_PORT=4000

# Optional: Container resource limits
CPU_LIMIT=4
MEMORY_LIMIT=8g
